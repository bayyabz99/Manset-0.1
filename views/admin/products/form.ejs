<%- include('../../partials/admin-layout-start') %>

<form id="productForm" class="form-admin admin-card" data-id="<%= product ? product.id : '' %>">
  <div class="form-row">
    <div>
      <label>Başlık *</label>
      <input type="text" name="title" value="<%= product?.title || '' %>" required>
    </div>
    <div>
      <label>SKU</label>
      <input type="text" name="sku" value="<%= product?.sku || '' %>">
    </div>
  </div>
  <div class="form-row">
    <div>
      <label>Fiyat (₺) *</label>
      <input type="number" step="0.01" name="price" value="<%= product?.price || '' %>" required>
    </div>
    <div>
      <label>İndirimli Fiyat (₺)</label>
      <input type="number" step="0.01" name="sale_price" value="<%= product?.sale_price || '' %>">
    </div>
  </div>
  <div class="form-row">
    <div>
      <label>Stok *</label>
      <input type="number" name="stock" value="<%= product?.stock ?? 0 %>" required>
    </div>
    <div>
      <label>Kategori</label>
      <select name="category_id">
        <option value="">— Seçin —</option>
        <% categories.forEach(function(c) { %>
          <option value="<%= c.id %>" <%= product?.category_id == c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div>
    <label>Açıklama</label>
    <textarea name="description"><%= product?.description || '' %></textarea>
  </div>
  <label class="checkbox-row"><input type="checkbox" name="is_featured" <%= product?.is_featured ? 'checked' : '' %>> Öne çıkan ürün</label>
  <label class="checkbox-row"><input type="checkbox" name="free_shipping" <%= product?.free_shipping ? 'checked' : '' %>> Ücretsiz kargo</label>
  <label class="checkbox-row"><input type="checkbox" name="is_active" <%= !product || product.is_active ? 'checked' : '' %>> Yayında</label>

  <% if (product) { %>
    <hr style="margin:1.5rem 0;border:none;border-top:1px solid #e5e5e5">
    <h3 style="margin-bottom:1rem">Görseller</h3>
    <div class="image-preview-grid" id="imageGrid">
      <% (product.images || []).forEach(function(img) { %>
        <img src="<%= img.path %>" alt="">
      <% }) %>
    </div>
    <input type="file" id="imageUpload" accept="image/*" style="margin-top:1rem">
  <% } %>

  <div class="form-actions">
    <button type="submit" class="btn-admin">Kaydet</button>
    <a href="/admin/urunler" class="btn-admin btn-admin-outline">İptal</a>
  </div>
</form>

<script>
document.getElementById('productForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  const id = form.dataset.id;
  const body = {
    title: form.title.value,
    sku: form.sku.value,
    price: form.price.value,
    sale_price: form.sale_price.value || null,
    stock: form.stock.value,
    category_id: form.category_id.value || null,
    description: form.description.value,
    is_featured: form.is_featured.checked,
    free_shipping: form.free_shipping.checked,
    is_active: form.is_active.checked,
  };
  const url = id ? `/api/admin/products/${id}` : '/api/admin/products';
  const method = id ? 'PUT' : 'POST';
  const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  const data = await res.json();
  if (!res.ok) return alert(data.error || 'Hata');
  if (!id) window.location.href = `/admin/urunler/${data.id}/duzenle`;
  else alert('Kaydedildi');
});
document.getElementById('imageUpload')?.addEventListener('change', async (e) => {
  const id = document.getElementById('productForm').dataset.id;
  if (!id || !e.target.files[0]) return;
  const fd = new FormData();
  fd.append('image', e.target.files[0]);
  const res = await fetch(`/api/admin/products/${id}/images`, { method: 'POST', body: fd });
  if (res.ok) location.reload();
  else alert('Görsel yüklenemedi');
});
</script>

<%- include('../../partials/admin-layout-end') %>
