<%- include('../partials/admin-layout-start') %>

<form id="settingsForm" class="form-admin admin-card">
  <h3 style="margin-bottom:1rem">İletişim Bilgileri</h3>
  <div class="form-row">
    <div><label>Site Adı</label><input name="site_name" value="<%= settings.site_name %>"></div>
    <div><label>Slogan</label><input name="site_tagline" value="<%= settings.site_tagline %>"></div>
  </div>
  <div class="form-row">
    <div><label>Telefon</label><input name="contact_phone" value="<%= settings.contact_phone %>"></div>
    <div><label>WhatsApp (ülke kodu ile)</label><input name="contact_whatsapp" value="<%= settings.contact_whatsapp %>"></div>
  </div>
  <div class="form-row">
    <div><label>E-posta</label><input name="contact_email" value="<%= settings.contact_email %>"></div>
    <div><label>Instagram URL</label><input name="instagram_url" value="<%= settings.instagram_url %>"></div>
  </div>
  <div><label>Adres</label><input name="contact_address" value="<%= settings.contact_address %>"></div>

  <h3 style="margin:2rem 0 1rem">Ödeme Yöntemleri</h3>
  <label class="checkbox-row"><input type="checkbox" name="payment_credit_card" <%= settings.payment_credit_card === '1' ? 'checked' : '' %>> Kredi Kartı ile Online Ödeme</label>
  <label class="checkbox-row"><input type="checkbox" name="payment_cash_on_delivery" <%= settings.payment_cash_on_delivery === '1' ? 'checked' : '' %>> Kapıda Nakit Ödeme</label>
  <label class="checkbox-row"><input type="checkbox" name="payment_card_on_delivery" <%= settings.payment_card_on_delivery === '1' ? 'checked' : '' %>> Kapıda Kart ile Ödeme</label>

  <h3 style="margin:2rem 0 1rem">Online Ödeme Entegrasyonu</h3>
  <p style="color:#737373;font-size:.875rem;margin-bottom:1rem">Iyzico veya Stripe anahtarlarını .env dosyasına ekleyin, ardından buradan aktif edin.</p>
  <label class="checkbox-row"><input type="checkbox" name="iyzico_enabled" <%= settings.iyzico_enabled === '1' ? 'checked' : '' %>> Iyzico Aktif</label>
  <label class="checkbox-row"><input type="checkbox" name="stripe_enabled" <%= settings.stripe_enabled === '1' ? 'checked' : '' %>> Stripe Aktif</label>

  <h3 style="margin:2rem 0 1rem">Kargo</h3>
  <div class="form-row">
    <div><label>Kargo Ücreti (₺)</label><input name="shipping_fee" type="number" value="<%= settings.shipping_fee %>"></div>
    <div><label>Ücretsiz Kargo Limiti (₺)</label><input name="free_shipping_threshold" type="number" value="<%= settings.free_shipping_threshold %>"></div>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn-admin">Ayarları Kaydet</button>
  </div>
</form>

<script>
document.getElementById('settingsForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const f = e.target;
  const body = {};
  ['site_name','site_tagline','contact_phone','contact_whatsapp','contact_email','instagram_url','contact_address','shipping_fee','free_shipping_threshold'].forEach(k => {
    body[k] = f[k].value;
  });
  ['payment_credit_card','payment_cash_on_delivery','payment_card_on_delivery','iyzico_enabled','stripe_enabled'].forEach(k => {
    body[k] = f[k].checked ? '1' : '0';
  });
  const res = await fetch('/api/admin/settings', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  if (res.ok) alert('Ayarlar kaydedildi');
});
</script>

<%- include('../partials/admin-layout-end') %>
