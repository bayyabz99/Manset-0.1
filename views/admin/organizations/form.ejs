<%- include('../../partials/admin-layout-start') %>

<form id="orgForm" class="form-admin admin-card" data-id="<%= org ? org.id : '' %>">
  <div class="form-row">
    <div>
      <label>Başlık *</label>
      <input type="text" name="title" value="<%= org?.title || '' %>" required>
    </div>
    <div>
      <label>Kategori</label>
      <select name="category_id">
        <option value="">— Seçin —</option>
        <% orgCategories.forEach(function(c) { %>
          <option value="<%= c.id %>" <%= org?.category_id == c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="form-row">
    <div>
      <label>Konum</label>
      <input type="text" name="location" value="<%= org?.location || '' %>" placeholder="Konya">
    </div>
    <div>
      <label>Etkinlik Tarihi</label>
      <input type="date" name="event_date" value="<%= org?.event_date || '' %>">
    </div>
  </div>
  <div>
    <label>Açıklama</label>
    <textarea name="description"><%= org?.description || '' %></textarea>
  </div>
  <label class="checkbox-row"><input type="checkbox" name="is_published" <%= !org || org.is_published ? 'checked' : '' %>> Yayında</label>
  <label class="checkbox-row"><input type="checkbox" name="is_featured" <%= org?.is_featured ? 'checked' : '' %>> Öne çıkan</label>

  <% if (org) { %>
    <hr style="margin:1.5rem 0;border:none;border-top:1px solid #e5e5e5">
    <h3>Görseller</h3>
    <div class="image-preview-grid">
      <% (org.images || []).forEach(function(img) { %>
        <img src="<%= img.path %>" alt="">
      <% }) %>
    </div>
    <input type="file" id="orgImageUpload" accept="image/*" style="margin-top:1rem">
  <% } %>

  <div class="form-actions">
    <button type="submit" class="btn-admin">Kaydet</button>
    <a href="/admin/organizasyonlar" class="btn-admin btn-admin-outline">İptal</a>
  </div>
</form>

<script>
document.getElementById('orgForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const f = e.target;
  const id = f.dataset.id;
  const body = {
    title: f.title.value,
    category_id: f.category_id.value || null,
    location: f.location.value,
    event_date: f.event_date.value || null,
    description: f.description.value,
    is_published: f.is_published.checked,
    is_featured: f.is_featured.checked,
  };
  const res = await fetch(id ? `/api/admin/organizations/${id}` : '/api/admin/organizations', {
    method: id ? 'PUT' : 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
  const data = await res.json();
  if (!res.ok) return alert(data.error);
  if (!id) location.href = `/admin/organizasyonlar/${data.id}/duzenle`;
  else alert('Kaydedildi');
});
document.getElementById('orgImageUpload')?.addEventListener('change', async (e) => {
  const id = document.getElementById('orgForm').dataset.id;
  const fd = new FormData();
  fd.append('image', e.target.files[0]);
  const res = await fetch(`/api/admin/organizations/${id}/images`, { method: 'POST', body: fd });
  if (res.ok) location.reload();
});
</script>

<%- include('../../partials/admin-layout-end') %>
