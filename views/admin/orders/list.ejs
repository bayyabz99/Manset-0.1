<%- include('../../partials/admin-layout-start') %>

<div class="admin-card">
  <div class="table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Sipariş No</th>
        <th>Müşteri</th>
        <th>Ödeme</th>
        <th>Toplam</th>
        <th>Durum</th>
        <th>Tarih</th>
      </tr>
    </thead>
    <tbody>
      <% const paymentLabels = { credit_card: 'Kredi Kartı', cash_on_delivery: 'Kapıda Nakit', card_on_delivery: 'Kapıda Kart' }; %>
      <% orders.forEach(function(o) { %>
        <tr>
          <td><strong><%= o.order_number %></strong></td>
          <td><%= o.customer_name %><br><small><%= o.customer_phone %></small></td>
          <td><%= paymentLabels[o.payment_method] || o.payment_method %></td>
          <td><%= formatPrice(o.total) %></td>
          <td>
            <select data-order-id="<%= o.id %>" class="order-status-select">
              <% ['new','confirmed','shipped','delivered','cancelled'].forEach(function(s) { %>
                <option value="<%= s %>" <%= o.order_status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </td>
          <td><%= new Date(o.created_at).toLocaleString('tr-TR') %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  </div>
</div>

<script>
document.querySelectorAll('.order-status-select').forEach(sel => {
  sel.addEventListener('change', async () => {
    await fetch(`/api/admin/orders/${sel.dataset.orderId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ order_status: sel.value }),
    });
  });
});
</script>

<%- include('../../partials/admin-layout-end') %>
