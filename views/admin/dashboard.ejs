<%- include('../partials/admin-layout-start') %>

<div class="stats-grid">
  <div class="stat-card"><strong><%= stats.products %></strong><span>Ürün</span></div>
  <div class="stat-card"><strong><%= stats.orders %></strong><span>Sipariş</span></div>
  <div class="stat-card"><strong><%= stats.organizations %></strong><span>Organizasyon</span></div>
</div>

<div class="admin-dashboard-grid">
  <div class="admin-card">
    <h3 style="margin-bottom:1rem">Son Siparişler</h3>
    <% if (!recentOrders.length) { %><p style="color:#737373">Henüz sipariş yok.</p><% } %>
    <div class="table-wrap">
      <table class="admin-table">
        <thead>
          <tr><th>Sipariş</th><th>Müşteri</th><th>Toplam</th></tr>
        </thead>
        <tbody>
          <% recentOrders.forEach(function(o) { %>
            <tr>
              <td><%= o.order_number %></td>
              <td><%= o.customer_name %></td>
              <td><%= formatPrice(o.total) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="admin-card">
    <h3 style="margin-bottom:1rem">Son Organizasyonlar</h3>
    <% if (!recentOrgs.length) { %><p style="color:#737373">Henüz organizasyon yok.</p><% } %>
    <% recentOrgs.forEach(function(o) { %>
      <p style="margin-bottom:.5rem"><a href="/admin/organizasyonlar/<%= o.id %>/duzenle"><%= o.title %></a></p>
    <% }) %>
  </div>
</div>

<%- include('../partials/admin-layout-end') %>
