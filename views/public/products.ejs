<%- include('../partials/header') %>

<div class="container shop-layout">
  <button type="button" class="mobile-filter-btn" id="filterToggle" aria-expanded="false">☰ Filtreler</button>

  <aside class="sidebar-panel" id="shopSidebar">
    <h3>Kategoriler</h3>
    <input type="text" class="filter-search" id="categorySearch" placeholder="Kategori ara...">
    <ul class="filter-list" id="categoryList">
      <li>
        <label>
          <input type="radio" name="kategori" value="tumu" form="filterForm" <%= filters.kategori === 'tumu' ? 'checked' : '' %>>
          Tümü
        </label>
      </li>
      <% categories.forEach(function(c) { %>
        <li data-name="<%= c.name.toLowerCase() %>">
          <label>
            <input type="radio" name="kategori" value="<%= c.slug %>" form="filterForm" <%= filters.kategori === c.slug ? 'checked' : '' %>>
            <%= c.name %>
          </label>
        </li>
      <% }) %>
    </ul>

    <div class="filter-section">
      <h3>Filtreler</h3>
      <ul class="filter-list">
        <li><label><input type="checkbox" name="indirimli" value="1" form="filterForm" <%= filters.indirimli ? 'checked' : '' %>> İndirimli Ürünler</label></li>
        <li><label><input type="checkbox" name="ucretsiz_kargo" value="1" form="filterForm" <%= filters.ucretsiz_kargo ? 'checked' : '' %>> Ücretsiz Kargo</label></li>
        <li><label><input type="checkbox" name="stokta" value="1" form="filterForm" <%= filters.stokta ? 'checked' : '' %>> Stokta Var</label></li>
      </ul>
    </div>
  </aside>

  <div class="shop-main">
    <form id="filterForm" method="get" action="/urunler">
      <div class="shop-header">
        <h1>Ürünler</h1>
        <div class="shop-toolbar">
          <div class="product-search-wrap">
            <input type="search" name="ara" class="product-search-input" value="<%= filters.ara %>" placeholder="Ürün ara..." aria-label="Ürün ara">
            <button type="submit" class="product-search-btn" aria-label="Ara">Ara</button>
          </div>
          <select name="sirala" class="sort-select" aria-label="Sıralama">
            <option value="popular" <%= filters.sirala === 'popular' ? 'selected' : '' %>>En Popüler</option>
            <option value="newest" <%= filters.sirala === 'newest' ? 'selected' : '' %>>En Yeni</option>
            <option value="price_asc" <%= filters.sirala === 'price_asc' ? 'selected' : '' %>>Fiyat ↑</option>
            <option value="price_desc" <%= filters.sirala === 'price_desc' ? 'selected' : '' %>>Fiyat ↓</option>
            <option value="name" <%= filters.sirala === 'name' ? 'selected' : '' %>>İsme Göre</option>
          </select>
        </div>
      </div>
      <% if (filters.ara) { %>
        <p class="search-result-hint"><%= products.length %> sonuç: "<strong><%= filters.ara %></strong>" <a href="/urunler">temizle</a></p>
      <% } %>
    </form>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <p>Bu filtrelere uygun ürün bulunamadı.</p>
        <a href="/urunler" class="btn btn-primary" style="margin-top:1rem">Filtreleri Temizle</a>
      </div>
    <% } else { %>
      <div class="product-grid">
        <% products.forEach(function(p) { %>
          <article class="product-card">
            <a href="/urun/<%= p.slug %>">
              <div class="product-card-image">
                <% if (p.discount_percent > 0) { %><span class="badge-discount">%<%= p.discount_percent %></span><% } %>
                <% if (p.stock <= 0) { %><span class="badge-soldout">TÜKENDİ</span><% } %>
                <% if (p.image_path) { %>
                  <img src="<%= p.image_path %>" alt="<%= p.title %>" loading="lazy">
                <% } else { %>
                  <div class="product-placeholder">🎈</div>
                <% } %>
              </div>
              <div class="product-card-body">
                <h3 class="product-card-title"><%= p.title %></h3>
                <div class="product-price">
                  <span class="price-current"><%= formatPrice(p.sale_price || p.price) %></span>
                  <% if (p.sale_price) { %><span class="price-old"><%= formatPrice(p.price) %></span><% } %>
                </div>
              </div>
            </a>
            <div class="product-card-body product-card-actions">
              <button class="btn-add" data-add-cart="<%= p.id %>" data-title="<%= p.title %>" data-price="<%= p.sale_price || p.price %>" data-slug="<%= p.slug %>" <%= p.stock <= 0 ? 'disabled' : '' %>>
                <%= p.stock <= 0 ? 'Tükendi' : 'Sepete Ekle' %>
              </button>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<div class="sidebar-overlay" id="shopSidebarOverlay"></div>

<script>
document.getElementById('categorySearch')?.addEventListener('input', function(e) {
  const q = e.target.value.toLowerCase();
  document.querySelectorAll('#categoryList li[data-name]').forEach(li => {
    li.style.display = li.dataset.name.includes(q) ? '' : 'none';
  });
});

const filterForm = document.getElementById('filterForm');
filterForm?.querySelectorAll('input[type="radio"], input[type="checkbox"]').forEach(el => {
  el.addEventListener('change', () => filterForm.submit());
});
filterForm?.querySelector('.sort-select')?.addEventListener('change', () => filterForm.submit());

const filterToggle = document.getElementById('filterToggle');
const shopSidebar = document.getElementById('shopSidebar');
const shopOverlay = document.getElementById('shopSidebarOverlay');

function closeShopSidebar() {
  shopSidebar?.classList.remove('open');
  shopOverlay?.classList.remove('visible');
  filterToggle?.setAttribute('aria-expanded', 'false');
}

filterToggle?.addEventListener('click', () => {
  const open = shopSidebar?.classList.toggle('open');
  shopOverlay?.classList.toggle('visible', open);
  filterToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
});
shopOverlay?.addEventListener('click', closeShopSidebar);
</script>

<%- include('../partials/footer') %>
