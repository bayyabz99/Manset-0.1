<%- include('../partials/header') %>

<div class="container product-detail">
  <div class="product-gallery">
    <div class="product-gallery-main">
      <% if (product.images && product.images.length) { %>
        <img src="<%= product.images[0].path %>" alt="<%= product.title %>" id="mainImage">
      <% } else { %>
        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:5rem">🎈</div>
      <% } %>
    </div>
  </div>
  <div class="product-info">
    <% if (product.category_name) { %>
      <span class="portfolio-tag"><%= product.category_name %></span>
    <% } %>
    <h1><%= product.title %></h1>
    <div class="product-price" style="margin:1rem 0">
      <span class="price-current" style="font-size:1.75rem"><%= formatPrice(product.sale_price || product.price) %></span>
      <% if (product.sale_price) { %>
        <span class="price-old"><%= formatPrice(product.price) %></span>
        <span class="badge-discount" style="position:static;display:inline-block;margin-left:.5rem">%<%= product.discount_percent %></span>
      <% } %>
    </div>
    <p style="color:var(--text-muted);margin-bottom:1rem">
      <%= product.stock > 0 ? '✓ Stokta (' + product.stock + ' adet)' : '✗ Tükendi' %>
      <% if (product.free_shipping) { %> · Ücretsiz kargo<% } %>
    </p>
    <% if (product.description) { %>
      <p><%= product.description %></p>
    <% } %>
    <div class="qty-control">
      <button type="button" id="qtyMinus">−</button>
      <input type="number" id="qty" value="1" min="1" max="<%= product.stock %>" readonly>
      <button type="button" id="qtyPlus">+</button>
    </div>
    <button class="btn btn-primary btn-block" id="addToCartBtn"
      data-id="<%= product.id %>"
      data-title="<%= product.title %>"
      data-price="<%= product.sale_price || product.price %>"
      data-slug="<%= product.slug %>"
      <%= product.stock <= 0 ? 'disabled' : '' %>>
      Sepete Ekle
    </button>
    <a href="https://wa.me/<%= settings?.contact_whatsapp %>?text=<%= encodeURIComponent(product.title + ' hakkında bilgi almak istiyorum') %>" class="btn btn-outline-dark btn-block" style="margin-top:.75rem" target="_blank">WhatsApp ile Sor</a>
  </div>
</div>

<% if (related.length) { %>
<section>
  <div class="container">
    <h2 class="section-title">Benzer Ürünler</h2>
    <div class="product-grid">
      <% related.forEach(function(p) { %>
        <a href="/urun/<%= p.slug %>" class="product-card">
          <div class="product-card-image">
            <% if (p.image_path) { %><img src="<%= p.image_path %>" alt="<%= p.title %>"><% } %>
          </div>
          <div class="product-card-body">
            <h3 class="product-card-title"><%= p.title %></h3>
            <span class="price-current"><%= formatPrice(p.sale_price || p.price) %></span>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<script>
const qty = document.getElementById('qty');
const max = <%= product.stock %>;
document.getElementById('qtyMinus')?.addEventListener('click', () => { if (+qty.value > 1) qty.value = +qty.value - 1; });
document.getElementById('qtyPlus')?.addEventListener('click', () => { if (+qty.value < max) qty.value = +qty.value + 1; });
document.getElementById('addToCartBtn')?.addEventListener('click', function() {
  const btn = this;
  Cart.add({
    product_id: +btn.dataset.id,
    title: btn.dataset.title,
    price: +btn.dataset.price,
    slug: btn.dataset.slug,
    quantity: +qty.value
  });
  alert('Ürün sepete eklendi!');
});
</script>

<%- include('../partials/footer') %>
