<%- include('../partials/header') %>

<section>
  <div class="container">
    <h1 class="section-title">Gerçekleştirdiğimiz İşler</h1>
    <p class="section-sub">Açılış organizasyonları, doğum günleri, hastane odası süslemeleri ve özel konseptler</p>

    <div class="category-tabs">
      <a href="/gerceklestirdigimiz-isler" class="<%= !activeCategory ? 'active' : '' %>">Tümü</a>
      <% orgCategories.forEach(function(c) { %>
        <a href="/gerceklestirdigimiz-isler?kategori=<%= c.slug %>" class="<%= activeCategory === c.slug ? 'active' : '' %>"><%= c.name %></a>
      <% }) %>
    </div>

    <% if (organizations.length === 0) { %>
      <div class="empty-state"><p>Henüz bu kategoride içerik yok.</p></div>
    <% } else { %>
      <div class="portfolio-grid">
        <% organizations.forEach(function(o) { %>
          <a href="/is/<%= o.slug %>" class="portfolio-card">
            <% if (o.image_path) { %>
              <img src="<%= o.image_path %>" alt="<%= o.title %>" loading="lazy">
            <% } else { %>
              <div style="aspect-ratio:4/3;background:#f5f5f5;display:flex;align-items:center;justify-content:center;font-size:3rem">🎉</div>
            <% } %>
            <div class="portfolio-card-body">
              <% if (o.category_name) { %><span class="portfolio-tag"><%= o.category_name %></span><% } %>
              <h3><%= o.title %></h3>
              <% if (o.location) { %><p style="color:var(--text-muted);font-size:.875rem;margin-top:.25rem">📍 <%= o.location %></p><% } %>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
