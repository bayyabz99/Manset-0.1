      <% } %>
      <a href="https://wa.me/<%= settings?.contact_whatsapp %>" class="whatsapp-btn" target="_blank" rel="noopener" style="margin-top:1.5rem">WhatsApp ile Yazın</a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
