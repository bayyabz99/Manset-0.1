<%- include('../partials/header') %>

<article class="container" style="padding:2rem 0 4rem;max-width:900px">
  <% if (org.category_name) { %><span class="portfolio-tag"><%= org.category_name %></span><% } %>
  <h1 style="font-size:2rem;margin:.5rem 0 1rem"><%= org.title %></h1>
  <% if (org.location || org.event_date) { %>
    <p style="color:var(--text-muted);margin-bottom:1.5rem">
      <% if (org.location) { %>📍 <%= org.location %><% } %>
      <% if (org.event_date) { %> · 📅 <%= org.event_date %><% } %>
    </p>
  <% } %>
  <% if (org.description) { %>
    <p style="margin-bottom:2rem;line-height:1.8"><%= org.description %></p>
  <% } %>
  <% if (org.images && org.images.length) { %>
    <div style="display:grid;gap:1rem">
      <% org.images.forEach(function(img) { %>
        <img src="<%= img.path %>" alt="<%= img.caption || org.title %>" style="border-radius:12px;width:100%" loading="lazy">
      <% }) %>
    </div>
  <% } %>
  <p style="margin-top:2rem">
    <a href="/gerceklestirdigimiz-isler" class="btn btn-outline-dark">← Tüm İşler</a>
    <a href="https://wa.me/<%= settings?.contact_whatsapp %>?text=<%= encodeURIComponent('Merhaba, ' + org.title + ' benzeri bir organizasyon için bilgi almak istiyorum.') %>" class="btn btn-primary" style="margin-left:.5rem" target="_blank">Teklif Al</a>
  </p>
</article>

<%- include('../partials/footer') %>
