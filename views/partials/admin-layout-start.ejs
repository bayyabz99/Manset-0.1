<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<div class="admin-sidebar-overlay" id="sidebarOverlay"></div>
<div class="admin-layout">
<%- include('admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar">
    <div class="admin-topbar-left">
      <button type="button" class="admin-menu-btn" id="sidebarToggle" aria-label="Menü">☰</button>
      <h1><%= title %></h1>
    </div>
    <div class="admin-topbar-actions">
      <a href="/" target="_blank" class="btn-admin btn-admin-outline btn-view-site">Siteyi Görüntüle</a>
      <div class="admin-user-menu">
        <button type="button" class="admin-user" id="userMenuBtn" aria-label="Hesap ayarları" aria-expanded="false">
          <%= (username || userName || 'A').charAt(0).toUpperCase() %>
        </button>
        <div class="admin-user-dropdown" id="userDropdown" hidden>
          <p class="admin-user-dropdown-title">Hesap Ayarları</p>
          <p class="admin-user-dropdown-sub">Kullanıcı: <strong id="currentUsername"><%= username || 'admin' %></strong></p>
          <form id="profileForm" class="profile-form">
            <label>Mevcut şifre *</label>
            <input type="password" name="current_password" required autocomplete="current-password">
            <label>Yeni kullanıcı adı</label>
            <input type="text" name="new_username" value="<%= username || '' %>" autocomplete="off" pattern="[a-zA-Z0-9._-]{3,32}" title="3-32 karakter, harf/rakam/.-_">
            <label>Yeni şifre</label>
            <input type="password" name="new_password" autocomplete="new-password" minlength="6" placeholder="En az 6 karakter">
            <p class="profile-form-hint">Kullanıcı adı veya şifreden en az birini değiştirin.</p>
            <button type="submit" class="btn-admin btn-admin-sm">Kaydet</button>
            <p class="profile-msg" id="profileMsg"></p>
          </form>
          <a href="/admin/cikis" class="admin-logout-link">Çıkış Yap</a>
        </div>
      </div>
    </div>
  </header>
  <div class="admin-content">
